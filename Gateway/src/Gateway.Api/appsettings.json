{
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "users-route": {
        "ClusterId": "users-cluster",
        "Match": {
          "Path": "/api/users/{**catch-all}"
        }
      },
      "rooms-route": {
        "ClusterId": "rooms-cluster",
        "Match": {
          "Path": "/api/rooms/{**catch-all}"
        }
      },
      "reservations-route": {
        "ClusterId": "reservations-cluster",
        "Match": {
          "Path": "/api/reservations/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://authservice:5000"
          }
        }
      },
      "users-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://userservice:5000"
          }
        }
      },
      "rooms-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://roomservice:5000"
          }
        }
      },
      "reservations-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://reservationservice:5000"
          }
        }
      }
    }
  },
  "Jwt": {
    "Issuer": "AuthService",
    "Audience": "AuthService.Client",
    "Key": "CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_WITH_AT_LEAST_32_CHARS"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}